# Copy this file to `.env` and adjust values as needed.

# ---------- Compose project / image tagging ---------- #
COMPOSE_PROJECT_NAME=dms
CUSTOM_IMAGE=custom-erpnext
CUSTOM_TAG=latest

# ---------- Site & credentials ---------- #
SITES=dms.localhost
SITE_NAME=dms.localhost
ADMIN_PASSWORD=admin
DB_ROOT_PASSWORD=admin

# ---------- Networking ---------- #
HTTP_PUBLISH_PORT=8080

# ---------- DMS version (git ref to install) ---------- #
# Use `main` for the latest, or pin a release tag like `v0.1.0`
# After changing this, edit `apps.json` to match and rebuild the image.
DMS_BRANCH=main
